# Default to LF in repo, auto-convert on checkout per-platform
* text=auto eol=lf

# Force LF for shell/python/web/config
*.sh    text eol=lf
*.py    text eol=lf
*.js    text eol=lf
*.ts    text eol=lf
*.jsx   text eol=lf
*.tsx   text eol=lf
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.toml  text eol=lf
*.md    text eol=lf
*.html  text eol=lf
*.css   text eol=lf

# Force CRLF for Windows-only files
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Binary - never touch
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.pdf   binary
*.zip   binary
*.exe   binary
*.dll   binary
*.ico   binary
*.woff  binary
*.woff2 binary
